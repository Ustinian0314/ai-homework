{
  "version": 2,
  "builds": [
    {
      "src": "proxy-server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
   {
  "src": "public/*.css",
  "use": "@vercel/static"
},
{
  "src": "public/*.js",
  "use": "@vercel/static"
}
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/proxy-server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/redesigned_AI.html"
    }
  ]
}
